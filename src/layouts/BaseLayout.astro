---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  lang?: 'zh' | 'en';
  frontmatter?: {
    title?: string;
    description?: string;
    lang?: 'zh' | 'en';
  };
}

const {
  title,
  description,
  lang,
  frontmatter,
} = Astro.props;
const pageTitle = title ?? frontmatter?.title ?? 'SOMER研究小组';
const pageDescription = description ?? frontmatter?.description ?? '土壤有机-矿物互作与生态修复研究小组。';
const pageLang = lang ?? frontmatter?.lang ?? 'zh';
const isEn = pageLang === 'en';
const navItems = isEn
  ? [
      { href: '/en/', label: 'Home' },
      { href: '/en/research/', label: 'Research' },
      { href: '/en/facilities/', label: 'Methods' },
      { href: '/en/people/', label: 'People' },
      { href: '/en/publications/', label: 'Publications' },
      { href: '/en/news/', label: 'News' },
      { href: '/en/contact/', label: 'Contact' },
    ]
  : [
      { href: '/', label: '首页' },
      { href: '/research/', label: '研究方向' },
      { href: '/facilities/', label: '研究方法' },
      { href: '/people/', label: '团队成员' },
      { href: '/publications/', label: '研究成果' },
      { href: '/news/', label: '组内动态' },
      { href: '/contact/', label: '联系我们' },
    ];
const currentPath = Astro.url.pathname;
const languageHref = isEn ? currentPath.replace(/^\/en(?=\/|$)/, '') || '/' : `/en${currentPath === '/' ? '/' : currentPath}`;
---
<!doctype html>
<html lang={isEn ? 'en' : 'zh-CN'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    <title>{pageTitle}</title>
    <link rel="icon" href="/favicon.svg" />
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header" aria-label={isEn ? 'Main navigation' : '主导航'}>
        <a class="brand" href={isEn ? '/en/' : '/'} aria-label={isEn ? 'SOMER Group home' : 'SOMER研究小组首页'}>
          <img class="brand-logo" src="/images/docx/image1.png" alt="SOMER logo" />
          <span>
            <strong>{isEn ? 'SOMER Group' : 'SOMER研究小组'}</strong>
            <small>Soil Organo-Mineral Interactions and Ecological Rehabilitation</small>
          </span>
        </a>
        <nav>
          {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
          <a class="language-switch" href={languageHref}>{isEn ? 'CN' : 'EN'}</a>
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <div>
          <strong>{isEn ? 'SOMER Group' : 'SOMER研究小组'}</strong>
          <p>Soil Organo-Mineral Interactions and Ecological Rehabilitation</p>
        </div>
        <a href={isEn ? '/en/contact/' : '/contact/'}>{isEn ? 'Contact' : '联系我们'}</a>
      </footer>
    </div>
  </body>
</html>
