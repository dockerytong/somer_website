---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'SOMER研究小组',
  description = '土壤有机-矿物互作与生态修复研究小组。',
} = Astro.props;
const navItems = [
  { href: '/', label: '首页' },
  { href: '/research/', label: '研究方向' },
  { href: '/people/', label: '团队成员' },
  { href: '/publications/', label: '研究成果' },
  { href: '/news/', label: '组内动态' },
  { href: '/contact/', label: '联系我们' },
];
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href="/favicon.svg" />
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header" aria-label="主导航">
        <a class="brand" href="/" aria-label="SOMER研究小组首页">
          <img class="brand-logo" src="/images/docx/image1.png" alt="SOMER logo" />
          <span>
            <strong>SOMER研究小组</strong>
            <small>Soil Organo-Mineral Interactions and Ecological Rehabilitation</small>
          </span>
        </a>
        <nav>
          {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <div>
          <strong>SOMER研究小组</strong>
          <p>Soil Organo-Mineral Interactions and Ecological Rehabilitation</p>
        </div>
        <a href="/contact/">联系我们</a>
      </footer>
    </div>
  </body>
</html>
