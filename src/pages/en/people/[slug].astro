---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import scholarData from '../../../data/scholar-publications.json';
import { enPeople } from '../../../data/en-site';

export async function getStaticPaths() {
  const entries = (await getCollection('people')).filter((entry) => entry.data.group === 'staff' || entry.slug === 'postdoc-na-li');
  return entries.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const person = enPeople[entry.slug] ?? entry.data;
const publications = scholarData.byPerson[entry.slug as keyof typeof scholarData.byPerson] ?? [];
---
<BaseLayout lang="en" title={`${person.name} | SOMER Group`} description={person.research}>
  <article class="content-card prose profile-page">
    <div class="profile-header">
      <div>
        <h1>{person.name}</h1>
        <p><strong>{person.role}</strong></p>
        {person.research && <p>{person.research}</p>}
      </div>
      {entry.data.photo && <img class="profile-photo" src={entry.data.photo} alt={person.name} />}
    </div>
    <p>
      {entry.data.email && <a class="text-link" href={`mailto:${entry.data.email}`}>Email</a>}
      {entry.data.email && entry.data.scholar && <span> · </span>}
      {entry.data.scholar && <a class="text-link" href={entry.data.scholar}>Google Scholar</a>}
    </p>
    {(person.period || person.origin || person.destination) && (
      <p>
        {person.period && <span>Period: {person.period}</span>}
        {person.origin && <span> · From: {person.origin}</span>}
        {person.destination && <span> · Current: {person.destination}</span>}
      </p>
    )}
    {person.bio?.map((paragraph) => <p>{paragraph}</p>)}
    {publications.length > 0 && (
      <>
        <h2>Publications</h2>
        <ol class="bib-list">
          {publications.map((paper) => (
            <li class="bib-item">
              <span class="bib-authors">{paper.authors}</span>
              {paper.year && <span> ({paper.year}). </span>}
              <span class="bib-title">{paper.title}. </span>
              {paper.journal && <span><em>{paper.journal}</em>.</span>}
            </li>
          ))}
        </ol>
      </>
    )}
  </article>
</BaseLayout>
