---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { enPeople } from '../../../data/en-site';

export async function getStaticPaths() {
  const entries = (await getCollection('people')).filter((entry) => entry.data.group === 'staff' || ['postdoc-na-li', 'postdoc-chenglong-lu', 'postdoc-minghan-wang'].includes(entry.slug));
  return entries.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const person = enPeople[entry.slug] ?? entry.data;
---
<BaseLayout lang="en" title={`${person.name} | SOMER Group`} description={person.research}>
  <article class="content-card prose profile-page">
    <div class="profile-header">
      <div>
        <h1>{person.name}</h1>
        <p><strong>{person.role}</strong></p>
        {person.research && <p>{person.research}</p>}
      </div>
      {entry.data.photo && <img class="profile-photo" src={entry.data.photo} alt={person.name} />}
    </div>
    <p>
      {entry.data.email && <a class="text-link" href={`mailto:${entry.data.email}`}>Email</a>}
      {entry.data.email && (entry.data.scholar || entry.data.researchgate) && <span> · </span>}
      {entry.data.scholar && <a class="text-link" href={entry.data.scholar}>Google Scholar</a>}
      {entry.data.scholar && entry.data.researchgate && <span> · </span>}
      {entry.data.researchgate && <a class="text-link" href={entry.data.researchgate}>ResearchGate</a>}
    </p>
    {(person.origin || person.destination) && (
      <p>
        {person.origin && <span>From: {person.origin}</span>}
        {person.destination && <span> · Current: {person.destination}</span>}
      </p>
    )}
    {person.bio?.map((paragraph) => <p>{paragraph}</p>)}
    {person.assistedStudents?.length && (
      <section class="assisted-students">
        <h2>Students Co-supervised</h2>
        <ul>
          {person.assistedStudents.map((student) => (
            <li>
              <strong>{student.name}</strong>
              <span>{student.role} · {student.institution}</span>
            </li>
          ))}
        </ul>
      </section>
    )}
  </article>
</BaseLayout>
