---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PersonCard from '../../../components/PersonCard.astro';
import PeopleTabs from '../../../components/PeopleTabs.astro';
import { enPeople } from '../../../data/en-site';

const people = (await getCollection('people'))
  .filter((person) => !person.data.hidden && person.data.group === 'alumni')
  .sort((a, b) => a.data.order - b.data.order);
const groups = [
  ['researcher', 'Former Postdoctoral Researchers and Visiting Scholars'],
  ['student', 'Former Students'],
] as const;
---
<BaseLayout lang="en" title="Alumni | SOMER Group" description="Alumni and former visitors of the SOMER Group.">
  <PeopleTabs lang="en" active="alumni" />
  {groups.map(([key, label]) => {
    const members = people.filter((person) => person.data.alumniType === key);
    if (!members.length) return null;
    return (
      <section class="member-section">
        <div class="section-heading"><h2>{label}</h2></div>
        <ul class="member-list member-list-two-column">
          {members.map((person) => {
            const translated = enPeople[person.slug] ?? {};
            return (
              <PersonCard
                name={translated.name ?? person.slug}
                role={translated.role ?? 'Alumni'}
                research={translated.research}
                origin={translated.origin}
                destination={translated.destination}
                group="alumni"
                lang="en"
              />
            );
          })}
        </ul>
      </section>
    );
  })}
</BaseLayout>
