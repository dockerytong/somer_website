---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PublicationCard from '../../../components/PublicationCard.astro';
import scholarData from '../../../data/scholar-publications.json';
import { earlyPublications } from '../../../data/early-publications';

const publications = scholarData.combined.filter((paper) => paper.year && paper.year >= 2023);
const years = [...new Set(publications.map((paper) => paper.year))];
---
<BaseLayout lang="en" title="Publications | SOMER Group">
  {years.map((year) => (
    <section class="pub-year-section">
      <h2>{year}</h2>
      <ol class="bib-list">
        {publications.filter((paper) => paper.year === year).map((paper) => <PublicationCard authors={paper.authors.split(', ').filter(Boolean)} journal={paper.journal} year={paper.year!} title={paper.title} />)}
      </ol>
    </section>
  ))}
  <section class="pub-year-section">
    <h2>Publications in 2022 and earlier</h2>
    <ol class="bib-list" start="22">
      {earlyPublications.map((paper) => <li class="bib-item">{paper}</li>)}
    </ol>
  </section>
</BaseLayout>
