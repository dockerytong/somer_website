---
import BaseLayout from '../layouts/BaseLayout.astro';

const cards = [
  {
    title: '同步辐射与先进谱学',
    items: [
      'XAFS：解析 Fe、Al、Si 等元素的价态、配位环境与矿物相转化。',
      '同步辐射 FTIR mapping：识别有机质官能团分布及其与矿物相的空间耦合关系。',
      'STXM：在微纳尺度解析有机质与矿物组分的共定位和界面结构。',
    ],
  },
  {
    title: '纳米与分子尺度表征',
    items: [
      'NanoSIMS：追踪微区元素分布和有机-矿物界面的空间关联。',
      '12T FTICR-MS：解析复杂环境样品中有机质的分子组成与分子转化特征。',
    ],
  },
  {
    title: '室内外实验平台',
    items: [
      '室内人工气候室：开展温度、水分、植物和微生物控制实验。',
      '大型自动化温室：进行较大尺度的尾矿修复和土壤过程模拟试验。',
      '生态定位实验站合作：支持长期定位观测与跨区域样地研究。',
    ],
  },
  {
    title: '合作共享设备',
    items: [
      'Bruker Vertex 80v 真空红外光谱（30 - 30000 cm-1）',
      'AFM（Bruker）',
      '共聚焦拉曼（Renishaw）',
      '显微红外（Bruker）',
      '元素分析仪（利曼）',
      'TOC/TN（multiCN 2100s，Jena）',
      '液相色谱（安捷伦 1260）',
      '气相色谱（岛津 GC2014，TCD/FID；安捷伦，FID/ECD）',
      'Picarro 水同位素分析仪',
    ],
  },
];
---
<BaseLayout title="平台方法 | SOMER研究小组" description="SOMER研究小组的核心技术能力、实验平台与合作表征资源。">
  <article class="facilities-page">
    <p class="facilities-intro">
      SOMER研究小组围绕尾矿成土、退化土壤修复、有机-矿物互作和元素生物地球化学过程，建立了从野外试验、室内控制实验到分子和纳米尺度表征的一体化研究框架。团队平台能力既依托现有实验条件，也建立在与大型装置、分析测试中心和生态定位站的长期合作基础上。
    </p>

    <div class="facilities-grid">
      {cards.map((card) => (
        <section class="facilities-card">
          <h2>{card.title}</h2>
          <ul>
            {card.items.map((item) => <li>{item}</li>)}
          </ul>
        </section>
      ))}
    </div>
  </article>
</BaseLayout>
