---
import BaseLayout from '../layouts/BaseLayout.astro';

const cards = [
  {
    title: '同步辐射与先进谱学',
    items: [
      'XAFS：解析 Fe、Al、Si 等元素的价态、配位环境与矿物相转化。',
      '同步辐射 FTIR mapping：识别有机质官能团分布及其与矿物相的空间耦合关系。',
      'STXM：在微纳尺度解析有机质与矿物组分的共定位和界面结构。',
    ],
  },
  {
    title: '纳米与分子尺度表征',
    items: [
      'NanoSIMS：追踪微区元素分布和有机-矿物界面的空间关联。',
      'FTICR-MS / Orbitrap-MS：解析复杂环境样品中有机质的分子组成与分子转化特征。',
      '微米 CT：重建团聚体和土壤孔隙的三维结构。',
    ],
  },
  {
    title: '室内外实验平台',
    items: [
      '室内人工气候室：开展温度、水分、植物和微生物控制实验。',
      '大型自动化温室：开展中尺度尾矿成土、植物建植和土壤过程模拟试验。',
      '矿区野外试验：在矿区开展千平米尺度的尾矿生态修复和成土过程验证。',
      '生态定位实验站合作：支持长期定位观测、跨区域样地比较和野外过程验证。',
    ],
  },
  {
    title: '合作共享分析资源',
    items: [
      '红外与显微红外光谱：表征矿物、有机质官能团及其空间分布。',
      '原子力显微镜与共聚焦拉曼：分析矿物表面形貌、界面结构和微区组分。',
      '元素分析、TOC/TN 与稳定同位素分析：定量土壤和尾矿中碳、氮、水分来源及转化过程。',
      '液相和气相色谱：分析小分子有机物、代谢产物及相关反应组分。',
    ],
  },
];
---
<BaseLayout title="研究方法 | SOMER研究小组" description="SOMER研究小组的核心研究方法、实验体系与合作表征资源。">
  <article class="facilities-page">
    <p class="facilities-intro">
      SOMER研究小组围绕尾矿成土、退化土壤修复、有机-矿物互作和元素生物地球化学过程，建立了从室内控制实验、中尺度温室试验到矿区野外验证，再到分子、纳米和三维结构表征的一体化研究框架。团队平台能力既依托现有实验条件，也建立在与大型装置、分析测试中心、商业测试平台、生态定位站和矿区现场的长期合作基础上。
    </p>

    <div class="facilities-grid">
      {cards.map((card) => (
        <section class="facilities-card">
          <h2>{card.title}</h2>
          <ul>
            {card.items.map((item) => <li>{item}</li>)}
          </ul>
        </section>
      ))}
    </div>
  </article>
</BaseLayout>
