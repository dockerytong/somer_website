---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import scholarData from '../../data/scholar-publications.json';

export async function getStaticPaths() {
  const entries = (await getCollection('people')).filter((entry) => entry.data.group === 'staff' || entry.slug === 'postdoc-na-li');
  return entries.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const publications = scholarData.byPerson[entry.slug as keyof typeof scholarData.byPerson] ?? [];
---
<BaseLayout title={`${entry.data.name} | SOMER研究小组`} description={entry.data.research}>
  <article class="content-card prose profile-page">
    <div class="profile-header">
      <div>
        <h1>{entry.data.name}</h1>
        <p><strong>{entry.data.role}</strong></p>
        {entry.data.research && <p>{entry.data.research}</p>}
      </div>
      {entry.data.photo && <img class="profile-photo" src={entry.data.photo} alt={entry.data.name} />}
    </div>
    <p>
      {entry.data.email && <a class="text-link" href={`mailto:${entry.data.email}`}>邮箱</a>}
      {entry.data.email && entry.data.scholar && <span> · </span>}
      {entry.data.scholar && <a class="text-link" href={entry.data.scholar}>Google Scholar</a>}
    </p>
    {(entry.data.period || entry.data.origin || entry.data.destination) && (
      <p>
        {entry.data.period && <span>在组时间：{entry.data.period}</span>}
        {entry.data.origin && <span> · 来源：{entry.data.origin}</span>}
        {entry.data.destination && <span> · 去向：{entry.data.destination}</span>}
      </p>
    )}
    <Content />
    {publications.length > 0 && (
      <>
        <h2>论文</h2>
        <ol class="bib-list">
          {publications.map((paper) => (
            <li class="bib-item">
              <span class="bib-authors">{paper.authors}</span>
              {paper.year && <span> ({paper.year}). </span>}
              <span class="bib-title">{paper.title}. </span>
              {paper.journal && <span><em>{paper.journal}</em>.</span>}
            </li>
          ))}
        </ol>
      </>
    )}
  </article>
</BaseLayout>
