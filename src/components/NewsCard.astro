---
interface Props {
  title: string;
  summary?: string;
  date: Date;
  href: string;
  locale?: string;
}
const { title, date, href, locale = 'zh-CN' } = Astro.props;
const formattedDate = new Intl.DateTimeFormat(locale, { year: 'numeric', month: 'long', day: 'numeric' }).format(date);
---
<li class="news-row">
  <time datetime={date.toISOString()}>{formattedDate}</time>
  <a href={href}>{title}</a>
</li>
